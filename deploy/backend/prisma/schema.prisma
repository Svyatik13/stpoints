generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  balance      Decimal  @default(0) @db.Decimal(18, 6)
  role         Role     @default(USER)
  isActive     Boolean  @default(true) @map("is_active")
  lastActiveAt DateTime? @map("last_active_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sentTransactions     Transaction[] @relation("sender")
  receivedTransactions Transaction[] @relation("receiver")
  miningChallenges     MiningChallenge[]
  giveawayWins         Giveaway[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model Transaction {
  id            String          @id @default(cuid())
  type          TransactionType
  amount        Decimal         @db.Decimal(18, 6)
  description   String?

  senderId      String?         @map("sender_id")
  sender        User?           @relation("sender", fields: [senderId], references: [id])

  receiverId    String          @map("receiver_id")
  receiver      User            @relation("receiver", fields: [receiverId], references: [id])

  balanceBefore Decimal         @db.Decimal(18, 6) @map("balance_before")
  balanceAfter  Decimal         @db.Decimal(18, 6) @map("balance_after")
  metadata      Json?

  createdAt     DateTime        @default(now()) @map("created_at")

  @@index([receiverId, createdAt])
  @@index([senderId, createdAt])
  @@index([type])
  @@map("transactions")
}

enum TransactionType {
  MINING_REWARD
  GIVEAWAY
  ADMIN_GRANT
  TRANSFER
  SYSTEM_DEBIT
}

model MiningChallenge {
  id             String          @id @default(cuid())
  userId         String          @map("user_id")
  user           User            @relation(fields: [userId], references: [id])

  prefix         String
  difficulty     Int
  target         String

  status         ChallengeStatus @default(PENDING)
  nonce          BigInt?
  resultHash     String?         @map("result_hash")
  hashesComputed Int?            @map("hashes_computed")

  reward         Decimal?        @db.Decimal(18, 6)

  issuedAt       DateTime        @default(now()) @map("issued_at")
  expiresAt      DateTime        @map("expires_at")
  solvedAt       DateTime?       @map("solved_at")

  @@index([userId, status])
  @@index([expiresAt])
  @@map("mining_challenges")
}

enum ChallengeStatus {
  PENDING
  SOLVED
  EXPIRED
  INVALID
}

model Giveaway {
  id        String   @id @default(cuid())
  winnerId  String   @map("winner_id")
  winner    User     @relation(fields: [winnerId], references: [id])
  amount    Decimal  @db.Decimal(18, 6)
  reason    String?
  pool      Int
  createdAt DateTime @default(now()) @map("created_at")

  @@index([winnerId])
  @@map("giveaways")
}

# ============================================
# stpoints.fun — Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --- Database ---
DATABASE_URL=postgresql://stpoints:stpoints_dev_2024@localhost:5432/stpoints

# --- JWT Secrets (CHANGE IN PRODUCTION!) ---
JWT_SECRET=dev-jwt-secret-change-me-in-production-abc123
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-in-production-xyz789
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Server ---
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# --- Mining ---
MINING_DIFFICULTY=5
MINING_REWARD_PER_10K=0.001
MINING_CHALLENGE_EXPIRY_MINUTES=10
MINING_MAX_HASH_RATE=500000

# --- Giveaway ---
GIVEAWAY_CRON=0 */6 * * *
GIVEAWAY_AMOUNT=0.5
GIVEAWAY_MIN_ACTIVE_HOURS=24

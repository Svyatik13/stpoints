generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String            @id @default(cuid())
  username             String            @unique
  passwordHash         String            @map("password_hash")
  balance              Decimal           @default(0) @db.Decimal(36, 18)
  role                 Role              @default(USER)
  isActive             Boolean           @default(true) @map("is_active")
  lastActiveAt         DateTime?         @map("last_active_at")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")
  miningStartedAt      DateTime?         @map("mining_started_at")
  referralCount        Int               @default(0) @map("referral_count")
  referrerId           String?           @map("referrer_id")
  address              String?           @unique @map("wallet_address")
  referralClicks       Int               @default(0) @map("referral_clicks")
  activeTitle          String?           @map("active_title")
  lastLoginRewardAt    DateTime?         @map("last_login_reward_at")
  loginStreak          Int               @default(0) @map("login_streak")
  chatMessages         ChatMessage[]
  coinflipsCreated     CoinflipGame[]    @relation("coinflipCreator")
  coinflipsJoined      CoinflipGame[]    @relation("coinflipJoiner")
  giveawayEntries      GiveawayEntry[]
  giveawayWins         GiveawayWinner[]
  giveawaysCreated     Giveaway[]        @relation("giveawayCreator")
  bids                 Bid[]
  marketListingsBought MarketListing[]   @relation("marketBuyer")
  marketListingsSold   MarketListing[]   @relation("marketSeller")
  miningChallenges     MiningChallenge[]
  stroom_sessions      stroom_sessions[]
  receivedTransactions Transaction[]     @relation("receiver")
  sentTransactions     Transaction[]     @relation("sender")
  wheelBets            WheelBet[]
  userPasses           UserPass[]
  usernames            Username[]
  referrer             User?             @relation("UserReferrals", fields: [referrerId], references: [id])
  referredUsers        User[]            @relation("UserReferrals")

  @@map("users")
}

model Transaction {
  id            String          @id @default(cuid())
  type          TransactionType
  amount        Decimal         @db.Decimal(36, 18)
  description   String?
  senderId      String?         @map("sender_id")
  receiverId    String          @map("receiver_id")
  balanceBefore Decimal         @map("balance_before") @db.Decimal(36, 18)
  balanceAfter  Decimal         @map("balance_after") @db.Decimal(36, 18)
  metadata      Json?
  createdAt     DateTime        @default(now()) @map("created_at")
  receiver      User            @relation("receiver", fields: [receiverId], references: [id])
  sender        User?           @relation("sender", fields: [senderId], references: [id])

  @@index([receiverId, createdAt])
  @@index([senderId, createdAt])
  @@index([type])
  @@map("transactions")
}

model MiningChallenge {
  id             String          @id @default(cuid())
  userId         String          @map("user_id")
  prefix         String
  difficulty     Int
  target         String
  status         ChallengeStatus @default(PENDING)
  nonce          BigInt?
  resultHash     String?         @map("result_hash")
  hashesComputed Int?            @map("hashes_computed")
  reward         Decimal?        @db.Decimal(36, 18)
  issuedAt       DateTime        @default(now()) @map("issued_at")
  expiresAt      DateTime        @map("expires_at")
  solvedAt       DateTime?       @map("solved_at")
  user           User            @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([expiresAt])
  @@map("mining_challenges")
}

model Giveaway {
  id           String           @id @default(cuid())
  title        String
  prizePool    Decimal          @db.Decimal(36, 18)
  winnerCount  Int              @map("winner_count")
  distribution Distribution     @default(EQUAL)
  status       GiveawayStatus   @default(ACTIVE)
  createdBy    String           @map("created_by")
  endsAt       DateTime         @map("ends_at")
  completedAt  DateTime?        @map("completed_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  participants GiveawayEntry[]
  winners      GiveawayWinner[]
  creator      User             @relation("giveawayCreator", fields: [createdBy], references: [id])

  @@map("giveaways")
}

model GiveawayEntry {
  id         String   @id @default(cuid())
  giveawayId String   @map("giveaway_id")
  userId     String   @map("user_id")
  joinedAt   DateTime @default(now()) @map("joined_at")
  giveaway   Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@unique([giveawayId, userId])
  @@map("giveaway_entries")
}

model GiveawayWinner {
  id         String   @id @default(cuid())
  giveawayId String   @map("giveaway_id")
  userId     String   @map("user_id")
  place      Int
  amount     Decimal  @db.Decimal(36, 18)
  giveaway   Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@map("giveaway_winners")
}

model UserPass {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  isUsed     Boolean   @default(false) @map("is_used")
  usedAt     DateTime? @map("used_at")
  obtainedAt DateTime  @default(now()) @map("obtained_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_passes")
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model PassCodeLog {
  id        String   @id @default(cuid())
  code      String
  type      String
  usedBy    String?  @map("used_by")
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("pass_code_logs")
}

model Username {
  id        String         @id @default(cuid())
  handle    String         @unique
  ownerId   String         @map("owner_id")
  canSellAt DateTime       @map("can_sell_at")
  isActive  Boolean        @default(true) @map("is_active")
  createdAt DateTime       @default(now()) @map("created_at")
  listing   MarketListing? @relation("listingUsername")
  owner     User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([handle])
  @@map("usernames")
}

model MarketListing {
  id                String        @id @default(cuid())
  type              ListingType
  price             Decimal       @db.Decimal(36, 18)
  status            ListingStatus @default(ACTIVE)
  sellerId          String        @map("seller_id")
  passId            String?       @map("pass_id")
  usernameId        String?       @unique @map("username_id")
  buyerId           String?       @map("buyer_id")
  soldAt            DateTime?     @map("sold_at")
  stDueAt           DateTime?     @map("st_due_at")
  stPaidAt          DateTime?     @map("st_paid_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  currentHighestBid Decimal?      @map("current_highest_bid") @db.Decimal(36, 18)
  endsAt            DateTime?     @map("ends_at")
  isAuction         Boolean       @default(false) @map("is_auction")
  minIncrement      Decimal?      @map("min_increment") @db.Decimal(36, 18)
  startingPrice     Decimal?      @map("starting_price") @db.Decimal(36, 18)
  note              String?       @map("note")
  bids              Bid[]
  buyer             User?         @relation("marketBuyer", fields: [buyerId], references: [id])
  seller            User          @relation("marketSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  username          Username?     @relation("listingUsername", fields: [usernameId], references: [id], onDelete: Cascade)

  @@index([status, type])
  @@index([stDueAt, stPaidAt])
  @@index([endsAt])
  @@map("market_listings")
}

model Bid {
  id        String        @id @default(cuid())
  listingId String        @map("listing_id")
  bidderId  String        @map("bidder_id")
  amount    Decimal       @db.Decimal(36, 18)
  createdAt DateTime      @default(now()) @map("created_at")
  bidder    User          @relation(fields: [bidderId], references: [id], onDelete: Cascade)
  listing   MarketListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([bidderId])
  @@map("market_bids")
}

model ActivityEvent {
  id        String   @id @default(cuid())
  type      String
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("activity_events")
}

model CoinflipGame {
  id         String         @id @default(cuid())
  amount     Decimal        @db.Decimal(36, 18)
  status     CoinflipStatus @default(WAITING)
  side       String         @default("heads")
  result     String?
  creatorId  String         @map("creator_id")
  joinerId   String?        @map("joiner_id")
  winnerId   String?        @map("winner_id")
  createdAt  DateTime       @default(now()) @map("created_at")
  resolvedAt DateTime?      @map("resolved_at")
  creator    User           @relation("coinflipCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  joiner     User?          @relation("coinflipJoiner", fields: [joinerId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([creatorId])
  @@map("coinflip_games")
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  message   String   @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("chat_messages")
}

model stroom_sessions {
  id         String   @id
  user_id    String
  teacher_id String
  cost       Decimal  @db.Decimal(36, 18)
  expires_at DateTime
  created_at DateTime @default(now())
  teachers   teachers @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
  users      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, expires_at])
}

model teachers {
  id              String            @id
  name            String            @unique
  is_active       Boolean           @default(true)
  created_at      DateTime          @default(now())
  rarity          TeacherRarity     @default(COMMON)
  stroom_sessions stroom_sessions[]
}

enum Role {
  USER
  ADMIN
}

enum TransactionType {
  MINING_REWARD
  GIVEAWAY
  ADMIN_GRANT
  TRANSFER
  SYSTEM_DEBIT
  ST_ROOM_ACCESS
  MARKET_SALE
  MARKET_PURCHASE
  HANDLE_CREATE
  REFERRAL_REWARD
  TIP
  COINFLIP_WIN
  COINFLIP_LOSS
  DAILY_REWARD
  AUCTION_REFUND
  WHEEL_WIN
  WHEEL_LOSS
}

enum ChallengeStatus {
  PENDING
  SOLVED
  EXPIRED
  INVALID
}

enum Distribution {
  EQUAL
  WEIGHTED
}

enum GiveawayStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ListingType {
  MYTHIC_PASS
  USERNAME
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
}

enum CoinflipStatus {
  WAITING
  FLIPPING
  FINISHED
  CANCELLED
}

enum WheelStatus {
  WAITING
  COUNTDOWN
  SPINNING
  FINISHED
}

enum TeacherRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
}

// ── Wheel Game ────────────────────────────────────────────────────────────────

model WheelRound {
  id            String      @id @default(cuid())
  totalAmount   Decimal     @default(0) @db.Decimal(36, 18)
  status        WheelStatus @default(WAITING)
  winnerId      String?     @map("winner_id")
  winningNumber Float?      @map("winning_number") // 0.00 - 100.00

  bets WheelBet[]

  createdAt  DateTime  @default(now()) @map("created_at")
  endsAt     DateTime? @map("ends_at") // when countdown ends
  resolvedAt DateTime? @map("resolved_at")

  @@index([status])
  @@map("wheel_rounds")
}

model WheelBet {
  id      String @id @default(cuid())
  roundId String @map("round_id")
  round   WheelRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount Decimal @db.Decimal(36, 18)

  // Probability slices (0.00 - 100.00)
  segmentStart Float @map("segment_start")
  segmentEnd   Float @map("segment_end")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([roundId])
  @@index([userId])
  @@map("wheel_bets")
}
